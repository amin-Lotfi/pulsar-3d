  /home/amin/Pictures/pulsar-3d/pulsar/main
  /home/amin/Pictures/pulsar-3d/pulsar/main --sync external --trigger-source Line2
  /home/amin/Pictures/pulsar-3d/pulsar/main --sync master --trigger-source Line2
  /home/amin/Pictures/pulsar-3d/pulsar/main --sync action --fps 60 --packet-size 8192
